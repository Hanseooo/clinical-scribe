# .env.example for ClinicalScribe (see src/lib/langchain/*)
# Only these variables are used by backend/LLM API

# Required: Google Gemini API Key for language model calls
GEMINI_API_KEY=

# Optional: Override Gemini API base URL (default provided in code)
#GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com
